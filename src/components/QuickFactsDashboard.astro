---
import { getI18n } from '../i18n/ui';
const { messages } = getI18n(Astro.url);
const q = messages.quickFactsDashboard;
const items = q.items ?? [];
const distanceMetrics = q.distanceMetrics ?? [];
---

<section id="quick-facts" class="section-padding" style="background: var(--bg-secondary);">
  <div class="max-w-6xl mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-3" style="color: var(--text-primary);">{q.title}</h2>
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--text-secondary);">{q.subtitle}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {items.map((it) => (
        <div class="rounded-3xl p-6 border h-full overflow-hidden relative" style="background: var(--card-bg); border-color: var(--border-color); box-shadow: var(--card-shadow);">
          <div class="absolute inset-x-0 top-0 h-1" style="background: color-mix(in srgb, var(--accent) 50%, transparent);"></div>
          <div class="flex items-start justify-between gap-4 mb-4">
            <div>
              <p class="text-xs uppercase tracking-[0.18em] mb-2" style="color: var(--text-muted);">{it.label}</p>
              <p class="text-3xl sm:text-4xl font-semibold leading-none tracking-tight" style="color: var(--text-primary);">{it.value}</p>
            </div>
            {it.icon && <span class="text-3xl opacity-80" aria-hidden="true">{it.icon}</span>}
          </div>
          {it.note && <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">{it.note}</p>}
        </div>
      ))}
    </div>

    {distanceMetrics.length > 0 && (
      <div class="mt-8 rounded-3xl p-6 md:p-8 border" style="background: var(--bg-primary); border-color: var(--border-color); box-shadow: var(--card-shadow);">
        <div class="max-w-3xl mb-6">
          {q.distanceTitle && <h3 class="font-display text-2xl font-semibold mb-2" style="color: var(--text-primary);">{q.distanceTitle}</h3>}
          {q.distanceSubtitle && <p class="text-sm sm:text-base leading-relaxed" style="color: var(--text-secondary);">{q.distanceSubtitle}</p>}
        </div>

        <div class="grid md:grid-cols-3 gap-4">
          {distanceMetrics.map((metric) => (
            <article class="rounded-2xl p-5 border h-full" style="background: var(--card-bg); border-color: var(--border-color);">
              <p class="text-xs uppercase tracking-[0.18em] mb-2" style="color: var(--text-muted);">{metric.label}</p>
              <p class="text-3xl font-semibold leading-none mb-3" style="color: var(--text-primary);">{metric.value}</p>
              {metric.note && <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">{metric.note}</p>}
            </article>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
