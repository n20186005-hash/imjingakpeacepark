---
import '../styles/global.css';
import Header from '../components/Header.astro';
import NoticeBanner from '../components/NoticeBanner.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, buildAlternates, htmlLangAttr, getI18n } from '../i18n/ui';
import { ogLocale, siteConfig } from '../config';

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const htmlLang = htmlLangAttr(lang);
const alts = buildAlternates(path);
const canonical = alts[lang] ?? alts.zh;
const { messages } = getI18n(Astro.url);
const schema = messages.schema ?? {};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: schema.name ?? 'Imjingak Pyeonghwa Nuri Park',
  alternateName: schema.alternateName ?? ['임진각 평화누리공원'],
  description: schema.description ?? messages.meta.description,
  url: canonical,
  mainEntityOfPage: canonical,
  image: schema.image ?? [
    'https://imjingakpeacepark.com/gallery/imjingak-pyeonghwa-nuri-park-1.jpg',
    'https://imjingakpeacepark.com/gallery/imjingak-pyeonghwa-nuri-park-3.jpg',
  ],
  touristType: schema.touristType ?? ['History travelers', 'Families', 'Photographers'],
  address: {
    '@type': 'PostalAddress',
    streetAddress: schema.streetAddress ?? '148-40 Imjingak-ro, Munsan-eup',
    addressLocality: schema.addressLocality ?? 'Paju-si',
    addressRegion: schema.addressRegion ?? 'Gyeonggi-do',
    postalCode: schema.postalCode ?? '10808',
    addressCountry: 'KR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: schema.latitude ?? 37.8902,
    longitude: schema.longitude ?? 126.7702,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
    },
  ],
  isAccessibleForFree: schema.isAccessibleForFree ?? true,
  publicAccess: schema.publicAccess ?? true,
  offers: [
    {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'KRW',
      url: canonical,
      description: messages.meta.description,
    },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.4',
    reviewCount: '7477',
  },
  sameAs: schema.sameAs ?? ['https://maps.app.goo.gl/dUgMXau27SzsDpqQ9'],
};
  const breadcrumbLd = (() => {
    const bc = messages.breadcrumb;
    return {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: bc.home, item: `${siteConfig.baseUrl}/${lang}` },
        { '@type': 'ListItem', position: 2, name: bc.region, item: `${siteConfig.baseUrl}/${lang}#overview` },
        { '@type': 'ListItem', position: 3, name: bc.city, item: `${siteConfig.baseUrl}/${lang}#transport` },
        { '@type': 'ListItem', position: 4, name: bc.current, item: canonical },
      ],
    };
  })();
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh" href={alts.zh} />
    <link rel="alternate" hreflang="en" href={alts.en} />
    <link rel="alternate" hreflang="ja" href={alts.ja} />
    <link rel="alternate" hreflang="ko" href={alts.ko} />
    <link rel="alternate" hreflang="x-default" href={alts.xDefault} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale[lang] ?? lang} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)}></script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)}></script>

    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>

    <slot name="head" />
  </head>
  <body class="min-h-screen">
    <Header />
    <NoticeBanner />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
